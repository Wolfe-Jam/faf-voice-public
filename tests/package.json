{
  "name": "faf-voice-v2-tests",
  "version": "2.0.0",
  "description": "Championship Test Suite for FAF-Voice V2.0 Cost Crisis Breakthrough",
  "scripts": {
    "test": "jest",
    "test:championship": "jest --coverage --verbose",
    "test:cost-validation": "jest cost-validation.test.js",
    "test:voice-functionality": "jest voice-functionality.test.js",
    "test:performance": "jest performance.test.js",
    "test:watch": "jest --watch",
    "test:report": "jest --coverage && node scripts/generate-report.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.4.1",
    "puppeteer": "^22.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "<rootDir>/setup.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!setup.js",
      "!fixtures/**"
    ],
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
